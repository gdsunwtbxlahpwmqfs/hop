# Qi Hop LLM 助手 - 环境变量模板
# =============================================================
# 本文件是 .env 的模板，供参考。
# 实际部署时，hop-deploy-llm.sh 会交互式生成 .env（权限 600），
# 无需手动复制本文件。
#
# 若需手动部署（不通过脚本），请复制本文件为 .env 并填入真实值：
#   cp env.example .env
#   vi .env
#   docker compose --env-file .env -f docker-compose.llm.yml up -d
# =============================================================

# DashScope API key (阿里云通义千问).
# 获取：阿里云控制台 → 模型服务灵积 → API Key
# 被 litellm-config.yaml 通过 os.environ/DASHSCOPE_API_KEY 读取
DASHSCOPE_API_KEY=

# DashScope API base URL (OpenAI compatible mode).
# - 公共端点: https://dashscope.aliyuncs.com/compatible-mode/v1
# - MaaS 实例: https://<instance>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# 被 litellm-config.yaml 通过 os.environ/DASHSCOPE_API_BASE 读取
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# -------------------------------------------------------------
# 以下为可选覆盖（hop-deploy-llm.sh 默认值见脚本头部）
# -------------------------------------------------------------
# LiteLLM 监听端口（默认 4000）
# LITELLM_PORT=4000

# Qdrant HTTP 端口（默认 6333）
# QDRANT_HTTP_PORT=6333

# Qdrant gRPC 端口（默认 6334）
# QDRANT_GRPC_PORT=6334

# Qdrant 日志级别（默认 INFO）
# QDRANT_LOG_LEVEL=INFO
