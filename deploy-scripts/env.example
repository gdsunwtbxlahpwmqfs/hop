# Qi Hop LLM 助手 - 环境变量模板
# =============================================================
# 本文件是 .env 的模板，供参考。
# 实际部署时，hop-deploy-llm.sh 会交互式生成 .env（权限 600），
# 无需手动复制本文件。
#
# 若需手动部署（不通过脚本），请复制本文件为 .env 并填入真实值：
#   cp env.example .env
#   vi .env
#   docker compose --env-file .env -f docker-compose.llm.yml up -d
# =============================================================

# LLM API key (vLLM, DashScope, OpenAI, etc.).
# 获取方式取决于您的上游提供商：
# - DashScope: 阿里云控制台 → 模型服务灵积 → API Key
# - OpenAI: platform.openai.com → API Keys
# - vLLM: 通常为空或自定义 token
# 被 litellm-config.yaml 通过 os.environ/LLM_API_KEY 读取
LLM_API_KEY=

# LLM API base URL (OpenAI compatible endpoint).
# 根据上游提供商选择：
# - vLLM: http://vllm:8000/v1
# - DashScope OpenAI: https://dashscope.aliyuncs.com/compatible-mode/v1
# - OpenAI: https://api.openai.com/v1
# - MaaS 实例: https://<instance>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# 被 litellm-config.yaml 通过 os.environ/LLM_API_BASE 读取
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# -------------------------------------------------------------
# 以下为可选覆盖（hop-deploy-llm.sh 默认值见脚本头部）
# -------------------------------------------------------------
# LiteLLM 监听端口（默认 4000）
# LITELLM_PORT=4000

# Qdrant HTTP 端口（默认 6333）
# QDRANT_HTTP_PORT=6333

# Qdrant gRPC 端口（默认 6334）
# QDRANT_GRPC_PORT=6334

# Qdrant 日志级别（默认 INFO）
# QDRANT_LOG_LEVEL=INFO
